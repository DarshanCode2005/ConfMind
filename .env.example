# ── LLM & Search APIs ─────────────────────────────────────────────────────────
OPENAI_API_KEY="your-openai-api-key"           # Required — used by agents + vector embeddings
SERPER_API_KEY="your-serper-api-key"           # Required — Google Search via Serper.dev
RAPIDAPI_KEY="your-rapidapi-key"               # Required — LinkedIn enrichment
SCRAPEGRAPH_API_KEY="your-scrapegraph-key"     # Required — ScrapeGraph-AI

# ── Vector Store (RAG memory) ──────────────────────────────────────────────────
USE_PINECONE="false"                           # Set to "true" to use Pinecone instead of local ChromaDB
PINECONE_API_KEY="your-pinecone-api-key"       # Required only if USE_PINECONE=true
CHROMA_PERSIST_DIR="./chroma_db"               # Local ChromaDB storage directory (ChromaDB mode only)

# ── Database (Supabase / PostgreSQL) ──────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://user:password@host:5432/confmind"
SUPABASE_URL="https://<your-project>.supabase.co"
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"

# ── FastAPI ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000"        # Comma-separated; add production URL here