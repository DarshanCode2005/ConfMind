# OpenRouter API key for LLM models (Gemma-2-27b-it, Gemma-2-9b-it)
OPENROUTER_API_KEY=""

# OpenAI API key for ChromaDB text embeddings (text-embedding-3-small)
OPENAI_API_KEY="""
# PredictHQ API key for fetching event, venue, and attendance data
PREDICTHQ_API_KEY=""

# Tavily API key for web search enrichment
TAVILY_API_KEY=""

# LangSmith tracing (optional but recommended for debugging)
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="confmind-backend"

# Ollama Fallback Settings (optional, if you want local fallback instead of pure API)
USE_OLLAMA="true"
OLLAMA_MODEL="confmind-planner"

# Pinecone Settings (optional, defaults to local ChromaDB if false)
USE_PINECONE="false"
PINECONE_API_KEY=""
PINECONE_ENV=""
