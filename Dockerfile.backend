# ──────────────────────────────────────────────────────────────────────────────
# ConfMind — Backend Dockerfile
# Python 3.12 slim — FastAPI / uvicorn entry point
# ChromaDB is persisted to /app/chroma_db (mount a Render Disk there)
# ──────────────────────────────────────────────────────────────────────────────

FROM python:3.12-slim AS base

# ---------- system deps --------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        curl \
        git \
        libpq-dev \
        libssl-dev \
        libffi-dev \
    && rm -rf /var/lib/apt/lists/*

# ---------- working directory --------------------------------------------------
WORKDIR /app

# ---------- Python dependencies -----------------------------------------------
# Copy only requirements first to leverage Docker layer caching
COPY requirements.txt ./

RUN pip install --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt

# ---------- application source ------------------------------------------------
# Copy the full repo (minus what is in .dockerignore)
COPY . .

# ---------- ChromaDB persistence dir -----------------------------------------
# Render Disk should be mounted at /app/chroma_db in the service settings.
# If no disk is attached the directory will still exist in-container (ephemeral).
RUN mkdir -p /app/chroma_db

# ---------- environment defaults (non-secret) ---------------------------------
# ChromaDB will always use local persistence (no Pinecone in production)
ENV USE_PINECONE=false
ENV CHROMA_PERSIST_DIR=/app/chroma_db
ENV USE_OLLAMA=false
ENV PORT=8000
# Allow all origins by default; override with ALLOWED_ORIGINS env var in Render
ENV ALLOWED_ORIGINS=*

# ---------- expose & start ----------------------------------------------------
EXPOSE 8000

# Use shell form so $PORT is expanded at runtime (Render injects PORT)
CMD uvicorn backend.main:api --host 0.0.0.0 --port ${PORT}
